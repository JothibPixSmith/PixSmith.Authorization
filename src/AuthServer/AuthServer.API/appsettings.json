{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=auth.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Identity": {
    "Password": {
      "RequiredLength": 8,
      "RequireDigit": true,
      "RequireUppercase": true,
      "RequireNonAlphanumeric": true
    },
    "Lockout": {
      "MaxFailedAccessAttempts": 5,
      "DefaultLockoutTimeSpanMinutes": 15
    }
  },
  "OpenIddict": {
    "BlazorClient": {
      "ClientId": "blazor-client",
      "BaseUri": "https://localhost:7100"
    },
    "M2MClient": {
      "ClientId": "m2m-client",
      "ClientSecret": "m2m-super-secret-change-in-production"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
