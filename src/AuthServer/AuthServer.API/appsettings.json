{
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=auth.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Identity": {
    "Password": {
      "RequiredLength": 8,
      "RequireDigit": true,
      "RequireUppercase": true,
      "RequireNonAlphanumeric": true
    },
    "Lockout": {
      "MaxFailedAccessAttempts": 5,
      "DefaultLockoutTimeSpanMinutes": 15
    }
  },
  "OpenIddict": {
    "BlazorClient": {
      "ClientId": "blazor-client",
      "BaseUri": "https://localhost:7100"
    },
    "M2MClient": {
      "ClientId": "m2m-client",
      "ClientSecret": "m2m-super-secret-change-in-production"
    }
  },
  "Email": {
    "FromAddress": "noreply@pixsmith.local",
    "FromName": "PixSmith Authorization",
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "EnableSsl": false,
      "Username": "",
      "Password": ""
    },
    "Outbox": {
      "PollIntervalSeconds": 5,
      "MaxAttempts": 5
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
