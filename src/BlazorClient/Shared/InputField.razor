@* InputField.razor *@
<div>
    <label class="block text-sm font-medium text-gray-700 mb-1">@Label</label>
    <input type="text"
           class="block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
           value="@Value"
           placeholder="@Placeholder"
           @oninput="OnInput" />
</div>
@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    private Task OnInput(ChangeEventArgs e) => ValueChanged.InvokeAsync(e.Value?.ToString());
}
