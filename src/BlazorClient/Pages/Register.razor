@page "/register"
@using System.ComponentModel.DataAnnotations
@inject IAccountApiService AccountApi
@inject NavigationManager Nav
@inject JwtAuthStateProvider AuthProvider

<PageTitle>Create Account - AuthServer</PageTitle>

<div class="min-h-[70vh] flex items-center justify-center">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-8 w-full max-w-sm space-y-6">

        <div class="text-center space-y-1">
            <div class="text-4xl">📝</div>
            <h1 class="text-2xl font-bold text-gray-800">Create an account</h1>
            <p class="text-sm text-gray-500">Sign up to get started with AuthServer</p>
        </div>

        @if (_submitted)
        {
            <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 text-sm text-green-700">
                Account created. Check your email for a confirmation link before signing in.
            </div>
            <a href="/login" class="block text-center text-sm text-blue-600 hover:underline">Back to sign in</a>
        }
        else
        {
            @if (_error is not null)
            {
                <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700">@_error</div>
            }

            <EditForm Model="_form" OnValidSubmit="HandleSubmit" class="space-y-4">
                <DataAnnotationsValidator />

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">First name</label>
                        <InputText @bind-Value="_form.FirstName"
                                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                                   autocomplete="given-name" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Last name</label>
                        <InputText @bind-Value="_form.LastName"
                                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                                   autocomplete="family-name" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                    <InputText @bind-Value="_form.Username"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="janedoe" autocomplete="username" />
                    <ValidationMessage For="@(() => _form.Username)" class="text-xs text-red-600 mt-1" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <InputText @bind-Value="_form.Email" type="email"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="you@example.com" autocomplete="email" />
                    <ValidationMessage For="@(() => _form.Email)" class="text-xs text-red-600 mt-1" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <InputText @bind-Value="_form.Password" type="password"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="••••••••" autocomplete="new-password" />
                    <ValidationMessage For="@(() => _form.Password)" class="text-xs text-red-600 mt-1" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Confirm password</label>
                    <InputText @bind-Value="_form.ConfirmPassword" type="password"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="••••••••" autocomplete="new-password" />
                    <ValidationMessage For="@(() => _form.ConfirmPassword)" class="text-xs text-red-600 mt-1" />
                </div>

                <button type="submit" disabled="@_loading"
                        class="w-full bg-blue-600 hover:bg-blue-700 disabled:opacity-50 text-white font-semibold py-2.5 px-4 rounded-lg transition">
                    @(_loading ? "Creating account…" : "Create account")
                </button>
            </EditForm>

            <p class="text-center text-sm text-gray-500">
                Already have an account?
                <a href="/login" class="text-blue-600 hover:underline">Sign in</a>
            </p>
        }
    </div>
</div>

@code {
    private readonly RegisterForm _form = new();
    private string? _error;
    private bool _loading;
    private bool _submitted;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
            Nav.NavigateTo("/admin");
    }

    private async Task HandleSubmit()
    {
        if (_form.Password != _form.ConfirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _error = null;
        _loading = true;
        try
        {
            var error = await AccountApi.RegisterAsync(
                _form.Username, _form.Email, _form.Password, _form.ConfirmPassword,
                _form.FirstName, _form.LastName);

            if (error is null)
                _submitted = true;
            else
                _error = error;
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class RegisterForm
    {
        [Required(ErrorMessage = "Username is required.")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password.")]
        public string ConfirmPassword { get; set; } = string.Empty;

        public string? FirstName { get; set; }
        public string? LastName { get; set; }
    }
}
