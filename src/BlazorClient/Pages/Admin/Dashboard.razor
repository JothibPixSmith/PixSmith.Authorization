@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject IAdminApiService AdminApi

<PageTitle>Admin Dashboard</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-800">🛡️ Admin Dashboard</h1>
        <div class="flex gap-2">
            <a href="/admin/users" class="btn-secondary">Manage Users</a>
            <a href="/admin/clients" class="btn-primary">Manage Clients</a>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else if (_stats is not null)
    {
        <!-- Stats Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <StatCard Label="Total Users" Value="@_stats.TotalUsers.ToString()" Color="blue" Icon="👥" />
            <StatCard Label="Active Users" Value="@_stats.ActiveUsers.ToString()" Color="green" Icon="✅" />
            <StatCard Label="Locked Users" Value="@_stats.LockedUsers.ToString()" Color="red" Icon="🔒" />
            <StatCard Label="OAuth Clients" Value="@_stats.TotalClients.ToString()" Color="purple" Icon="🔗" />
        </div>

        <!-- Recent Logins Table -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="font-semibold text-gray-700">Recent Sign-Ins</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Login</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-100">
                        @foreach (var login in _stats.RecentLogins)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">@login.Username</td>
                                <td class="px-6 py-4 text-sm text-gray-500">@login.Email</td>
                                <td class="px-6 py-4 text-sm text-gray-400">@login.LoginAt.ToString("MMM d, yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (_error is not null)
    {
        <ErrorAlert Message="@_error" />
    }
</div>

@code {
    private DashboardStatsModel? _stats;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _stats = await AdminApi.GetDashboardStatsAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load dashboard: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
