{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Auth Server (API)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: AuthServer.API",
      "program": "${workspaceFolder}/src/AuthServer/AuthServer.API/bin/Debug/net10.0/PixSmith.Authorization.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/AuthServer/AuthServer.API",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      }
    },
    {
      "name": "Blazor Client Server",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: BlazorClient.Server",
      "program": "${workspaceFolder}/src/BlazorClient.Server/bin/Debug/net10.0/PixSmith.Authorization.BlazorClient.Server.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/BlazorClient.Server",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ],
  "compounds": [
    {
      "name": "Auth Server + Blazor Client",
      "configurations": ["Auth Server (API)", "Blazor Client Server"],
      "stopAll": true
    }
  ]
}
