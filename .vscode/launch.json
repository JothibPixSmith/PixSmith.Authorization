{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Auth Server (API)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: AuthServer.API",
      "program": "${workspaceFolder}/src/AuthServer/AuthServer.API/bin/Debug/net10.0/PixSmith.Authorization.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/AuthServer/AuthServer.API",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Blazor Client (WASM)",
      "type": "blazorwasm",
      "request": "launch",
      "preLaunchTask": "build: BlazorClient",
      "cwd": "${workspaceFolder}/src/BlazorClient",
      "url": "https://localhost:7200"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (API + Blazor)",
      "configurations": ["Auth Server (API)", "Blazor Client (WASM)"],
      "stopAll": true
    }
  ]
}
